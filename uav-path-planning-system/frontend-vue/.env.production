# Cesium Ion 访问令牌（生产环境）
# 请替换为你自己的 Cesium Ion Access Token
#
# 获取方式：
#   1. 注册/登录 https://ion.cesium.com
#   2. 导航到 Access Tokens > Create Token
#   3. 在 Token Permissions 中勾选以下 assets:
#      - Cesium World Terrain (asset id: 1)
#      - Bing Maps imagery (asset id: 2)
#   4. 在 Allowed Origins 中添加你的生产域名:
#      https://your-production-domain.com
#   5. 复制生成的 Token 替换下方占位符
#
# 安全提示：
#   - 不要在客户端代码中暴露具有完整权限的 Token
#   - 使用 Cesium Ion 的 Token 白名单功能限制来源域名
#   - 定期轮换 Token
#
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# API 基础 URL（生产环境）
# 替换为实际生产环境 API 网关地址
VITE_API_BASE_URL=/api

# WebSocket URL（生产环境）
VITE_WS_URL=wss://your-production-domain.com/ws

# 启用 Cesium 调试（生产环境保持 false）
VITE_ENABLE_DEVTOOLS=false

# 控制台日志级别（production 仅输出 error 级别）
VITE_LOG_LEVEL=warn
