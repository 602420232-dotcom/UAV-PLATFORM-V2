# ==========================================
# UAV Path Planning System - Environment Template
# ==========================================
#
# ╔══════════════════════════════════════════════════════════════╗
# ║  🔴 SECURITY NOTICE                                         ║
# ║                                                             ║
# ║  This is a TEMPLATE file. Copy it to .env and fill in       ║
# ║  your own values. NEVER commit the actual .env file.        ║
# ║                                                             ║
# ║  Generate production secrets using:                         ║
# ║    Linux:   openssl rand -base64 32                         ║
# ║    PS:      [Convert]::ToBase64String((1..32|%{Get-Random   ║
# ║               -Max 256}))                                   ║
# ║                                                             ║
# ║  For production: use external Secrets Provider              ║
# ║  (HashiCorp Vault / AWS Secrets Manager / Azure Key Vault   ║
# ║   / GCP Secret Manager) to inject real credentials.         ║
# ╚══════════════════════════════════════════════════════════════╝

# ===== Environment =====
ENVIRONMENT=development

# ===== Security Configuration =====
# 🔑 Generate with: openssl rand -base64 32
JWT_SECRET_KEY=change-me-to-a-random-256-bit-key

# 🔑 Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change-me-to-a-random-256-bit-key-base64-encoded

# ===== Database Configuration =====
DB_PASSWORD=change-me-to-a-secure-database-password

# ===== CORS Configuration =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===== Service URLs =====
SERVICES_WRF_PROCESSOR_URL=http://wrf-processor:8081/api/wrf
SERVICES_DATA_ASSIMILATION_URL=http://data-assimilation:8084/api/assimilation
SERVICES_METEOR_FORECAST_URL=http://meteor-forecast:8082/api/forecast
SERVICES_PATH_PLANNING_URL=http://path-planning:8083/api/planning

# ===== Redis Configuration =====
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# ===== Nacos Configuration =====
NACOS_SERVER=nacos:8848

# ===== Python Configuration =====
UAV_PYTHON_SCRIPT_PATH=/app/python
UAV_PYTHON_TIMEOUT=30000

# ===== Logging Configuration =====
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===== Monitoring Configuration =====
ENABLE_METRICS=true
ENABLE_TRACING=true

# ===== Security Headers =====
ENABLE_SECURITY_HEADERS=true
CONTENT_SECURITY_POLICY=default-src 'self'
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# ===== Rate Limiting =====
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_ENABLED=true

# ===== Feature Flags =====
ENABLE_SWAGGER_UI=true
ENABLE_ACTUATOR_ENDPOINTS=true

# ===== Test Configuration (DEVELOPMENT ONLY) =====
TEST_USERNAME=test_admin
TEST_PASSWORD=test_pass_123

# ===== MySQL Root Password =====
MYSQL_ROOT_PASSWORD=your-secure-root-password

# ===== Security Default Password =====
SECURITY_USER_PASSWORD=admin123

# ===== Redis Password =====
REDIS_PASSWORD=

# ===== Weather API Key =====
WEATHER_API_KEY=

# ===== Kafka Host =====
KAFKA_HOST=localhost
