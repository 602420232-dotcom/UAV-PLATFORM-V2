# ================================================================
# UAV Path Planning System - Environment Configuration
# ================================================================
# Copy this file to .env and modify for your environment
#   cp .env.example .env
# ================================================================

# ─── Database ──────────────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS
DB_ROOT_PASSWORD=${DB_PASSWORD}
DB_HOST=mysql
DB_PORT=3306

# ─── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT Authentication ────────────────────────────────────────
JWT_SECRET=uav-platform-jwt-secret-must-be-256-bits-long-for-hs512
JWT_SECRET_KEY=${JWT_SECRET}
JWT_EXPIRATION=86400000

# ─── Nacos ─────────────────────────────────────────────────────
NACOS_SERVER=nacos:8848
NACOS_NAMESPACE=
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ─── Service Ports ─────────────────────────────────────────────
API_GATEWAY_PORT=8088
UAV_PLATFORM_PORT=8080
WRF_PROCESSOR_PORT=8081
METEOR_FORECAST_PORT=8082
PATH_PLANNING_PORT=8083
DATA_ASSIMILATION_PORT=8084
FENGWU_SERVICE_PORT=8085
WEATHER_COLLECTOR_PORT=8086
EDGE_COORDINATOR_PORT=8000
EDGE_WS_PORT=8765

# ─── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Security ──────────────────────────────────────────────────
SECURITY_USER_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
FENGWU_API_KEY=
JWT_ISSUER=uav-platform
JWT_AUDIENCE=uav-frontend

# ─── Logging ───────────────────────────────────────────────────
LOG_PATH=/logs
LOG_LEVEL=INFO
ENVIRONMENT=production

# ─── Monitoring ────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
PROMETHEUS_RETENTION=30d
ALERTMANAGER_WEBHOOK_URL=

# ─── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=uav

# ─── External Services ─────────────────────────────────────────
NVD_API_KEY=
SENTRY_DSN=

# ─── JVM Options (Docker) ──────────────────────────────────────
JAVA_OPTS_SMALL=-Xms256m -Xmx512m
JAVA_OPTS_MEDIUM=-Xms512m -Xmx1g
JAVA_OPTS_LARGE=-Xms1g -Xmx2g

# ─── Python ────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
